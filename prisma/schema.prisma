generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum ProjectStatus {
  OPEN
  REVIEWING
  FILLED
  ARCHIVED
}

enum ApplicationStatus {
  SUBMITTED
  INTERVIEW
  ACCEPTED
  DECLINED
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String
  role           Role          @default(STUDENT)
  department     String?
  majorOrTitle   String?
  graduationYear Int?
  bio            String?
  portfolioUrl   String?
  githubUrl      String?
  resumeUrl      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  skills         UserSkill[]
  interests      UserInterest[]
  ownedProjects  Project[]     @relation("ProjectOwner")
  applications   Application[]
  savedProjects  SavedProject[]
}

model Skill {
  id       String         @id @default(cuid())
  name     String         @unique
  users    UserSkill[]
  projects ProjectSkill[]
}

model Interest {
  id    String         @id @default(cuid())
  name  String         @unique
  users UserInterest[]
}

model UserSkill {
  userId  String
  skillId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

model UserInterest {
  userId     String
  interestId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
}

model Project {
  id             String          @id @default(cuid())
  title          String
  description    String
  ownerId        String
  owner          User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  category       String
  departments    String[]
  commitment     String
  duration       String
  goals          String[]
  status         ProjectStatus   @default(OPEN)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  skills         ProjectSkill[]
  applications   Application[]
  savedBy        SavedProject[]
  recommendation ProjectVector?
}

model ProjectSkill {
  projectId String
  skillId   String
  required  Boolean @default(true)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([projectId, skillId])
}

model Application {
  id          String            @id @default(cuid())
  projectId   String
  applicantId String
  message     String?
  status      ApplicationStatus @default(SUBMITTED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applicant   User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([projectId, applicantId])
}

model SavedProject {
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model ProjectVector {
  projectId String   @id
  // Store embeddings in pgvector once the extension is enabled in the production database.
  embedding Unsupported("vector")?
  summary   String
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
